# GEMINI_API_KEY: Required for server-side Gemini API calls.
# Generate from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# AUTH_SECRET: Secret used to sign session cookies.
AUTH_SECRET="replace-with-strong-random-secret"

# Demo credential pairs for role-based login.
APP_ADMIN_EMAIL="admin@example.com"
APP_ADMIN_PASSWORD="change-admin-password"
APP_MEMBER_EMAIL="member@example.com"
APP_MEMBER_PASSWORD="change-member-password"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
